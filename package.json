{
  "name": "comic-canvas-studio",
  "version": "0.0.0",
  "private": true,
  "description": "Local-first AIGC comic-drama canvas and agent orchestration desktop client.",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "shared",
    "desktop"
  ],
  "engines": {
    "bun": ">=1.3.14",
    "node": ">=20"
  },
  "type": "module",
  "scripts": {
    "dev": "bun run --filter @comic-canvas/desktop dev",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "bun run --filter @comic-canvas/desktop build && tsc -p tsconfig.build.json",
    "verify:repo": "bun scripts/verify-repo.mjs",
    "release:dry-run": "bun scripts/release-dry-run.mjs",
    "ci": "bun run lint && bun run typecheck && bun run test && bun run build && bun run verify:repo"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  }
}
