# ComicCanvas Studio — 环境变量示例
#
# 复制为 .env 后按需修改（.env 已被 .gitignore 忽略，不会入库）。
# 说明：模型网关的 API Key 不放这里，走 OS 安全存储或本地 git-ignored 的
#       local-gateways.json（见下方 COMIC_CANVAS_GATEWAYS_FILE）。

# --- 开发调试 ---------------------------------------------------------------

# 是否打开 Electron DevTools。
#   1 = 强制打开，0 = 强制关闭，留空 = 按默认（dev 打开 / 生产关闭）。
COMIC_CANVAS_DEVTOOLS=

# 渲染层调试日志开关（debug 库）。示例：comic-canvas:*
DEBUG=

# --- 模型网关引导 -----------------------------------------------------------

# 本地网关引导文件的绝对路径（包含 provider baseUrl / apiKey / modelMap）。
# 留空时默认读取应用根目录下的 local-gateways.json（该文件已被 git 忽略）。
# 文件格式：
#   {
#     "gateways": [
#       {
#         "id": "openai-main",
#         "name": "OpenAI Compatible",
#         "type": "openai_compat",
#         "baseUrl": "https://api.example.com/v1",
#         "apiKey": "sk-...",
#         "capabilities": ["text", "image", "video"],
#         "modelMap": { "text": "gpt-4o-mini", "image": "...", "video": "..." },
#         "enabled": true
#       }
#     ]
#   }
COMIC_CANVAS_GATEWAYS_FILE=

# --- Electron / Vite dev server（一般由工具链自动注入，无需手动设置）---------

# 渲染层 dev server 地址，由 electron-vite 注入。
# ELECTRON_RENDERER_URL=
# dev server 端口。
# PORT=
