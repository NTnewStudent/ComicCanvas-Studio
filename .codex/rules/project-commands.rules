# Codex exec policy rules for ComicCanvas Studio.
# These rules control commands requested outside the sandbox. They are loaded
# only when the project .codex layer is trusted.

prefix_rule(
    pattern = ["bun", "run"],
    decision = "allow",
    justification = "Project Bun scripts are expected verification and development commands.",
    match = ["bun run test", "bun run build", "bun run lint", "bun run ci"],
)

prefix_rule(
    pattern = ["bun", "x"],
    decision = "allow",
    justification = "bun x is allowed for local project tooling and one-off verification.",
    match = ["bun x tsc --noEmit", "bun x vitest run"],
)

prefix_rule(
    pattern = ["bun"],
    decision = "allow",
    justification = "Bun is the repository package manager and script runner.",
    match = ["bun install --frozen-lockfile", "bun scripts/verify-repo.mjs"],
)

prefix_rule(
    pattern = ["git", ["status", "log", "diff"]],
    decision = "allow",
    justification = "Read-only git inspection is safe and expected.",
    match = ["git status --short", "git log --oneline -5", "git diff -- shared/plan.ts"],
)

prefix_rule(
    pattern = ["git", "add"],
    decision = "prompt",
    justification = "Staging changes is allowed after review, but should remain explicit.",
    match = ["git add AGENTS.md"],
)

prefix_rule(
    pattern = ["git", "commit"],
    decision = "prompt",
    justification = "Committing is allowed only after explicit user intent and verification.",
    match = ["git commit -m update"],
)

prefix_rule(
    pattern = ["git", "push", "--force"],
    decision = "forbidden",
    justification = "Force push is forbidden by project safety rules.",
    match = ["git push --force", "git push --force-with-lease"],
)

prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "forbidden",
    justification = "Hard reset can destroy user work. Ask the user for an explicit recovery plan instead.",
    match = ["git reset --hard", "git reset --hard HEAD"],
)

prefix_rule(
    pattern = ["rm", "-rf", "/"],
    decision = "forbidden",
    justification = "Destructive root deletion is forbidden.",
    match = ["rm -rf /"],
)
